#include "../bun.h"
#include <stdlib.h>
#include <stdarg.h>
#include <string.h>
#include <errno.h>

// --- Prologue ---

// Helper: terminate abnormally, after printing a message to stderr
void die(const char *fmt, ...)
{
  va_list args;
  va_start(args, fmt);

  fprintf(stderr, "fatal error: ");
  vfprintf(stderr, fmt, args);
  fprintf(stderr, "\n");

  va_end(args);

  abort();
}

// Helper: open a test fixture by name, relative to the tests/ directory.
static const char *fixture(const char *filename) {
    // For simplicity, tests assume they are run from the project root, and
    // test BUN files live in tests/fixtures/{valid,invalid}. Adjust if needed.
    static char path[256];
    int res = snprintf(path, sizeof(path), "tests/fixtures/%s", filename);
    if (res < 0) {
      die("snprintf failed: %s", strerror(errno));
    }
    if ((size_t) res > sizeof(path)) {
      die("filename '%s' too big for buffer (would write %d bytes to %zu-size buffer)",
          filename, res, sizeof(path));
    }
    return path;
}

// Helper: asserts invalid bun files
void assert_bun_status(const char* filename, bun_result_t expected) {
    BunParseContext ctx = {0};
    BunHeader header    = {0};

    bun_result_t r = bun_open(fixture(filename), &ctx);
    ck_assert_int_eq(r, BUN_OK);

    r = bun_parse_header(&ctx, &header);
    ck_assert_int_eq(r, expected);

    bun_close(&ctx);
}

// --- Tests ---

#test test_valid_minimal
    BunParseContext ctx = {0};
    BunHeader header    = {0};

    bun_result_t r = bun_open(fixture("valid/01-empty.bun"), &ctx);
    ck_assert_int_eq(r, BUN_OK);

    r = bun_parse_header(&ctx, &header);
    ck_assert_int_eq(r, BUN_OK);
    ck_assert_uint_eq(header.magic, BUN_MAGIC);
    ck_assert_uint_eq(header.version_major, 1);
    ck_assert_uint_eq(header.version_minor, 0);

    bun_close(&ctx);

#test test_bad_magic
    assert_bun_status("invalid/01-bad-magic.bun", BUN_MALFORMED);

#test test_unsupported_version
    assert_bun_status("invalid/02-bad-version.bun", BUN_UNSUPPORTED);

#test test_bad_offset_alignment
    assert_bun_status("invalid/03-bad-offset-alignment.bun", BUN_MALFORMED);

#test test_section_past_eof
    assert_bun_status("invalid/04-section-past-eof.bun", BUN_MALFORMED);

#test test_overlapping_sections
    assert_bun_status("invalid/05-overlapping-sections.bun", BUN_MALFORMED);

#test test_asset_name_past_string_table
    assert_bun_status("invalid/06-asset-name-past-string-table.bun", BUN_MALFORMED);

#test test_asset_name_nonprintable
    assert_bun_status("invalid/07-asset-name-nonprintable.bun", BUN_MALFORMED);

#test test_truncated_file
    assert_bun_status("invalid/08-truncated-file.bun", BUN_MALFORMED);

#test test_misaligned_section_size
    assert_bun_status("invalid/09-misaligned-section-size.bun", BUN_MALFORMED);

#test test_overlapping_with_nonprintable
    assert_bun_status("invalid/10-overlapping-with-nonprintable.bun", BUN_MALFORMED);

#test test_second_asset_empty_name
    assert_bun_status("invalid/11-second-asset-empty-name.bun", BUN_MALFORMED);

#test test_asset_name_oob
    assert_bun_status("invalid/12-asset-name-oob.bun", BUN_MALFORMED);

#test test_asset_empty_name
    assert_bun_status("invalid/13-asset-empty-name.bun", BUN_MALFORMED);

#test test_rle_zero_count
    assert_bun_status("invalid/14-rle-zero-count.bun", BUN_MALFORMED);

#test test_rle_bomb
    assert_bun_status("invalid/15-rle-bomb.bun", BUN_MALFORMED);

#test test_rle_truncated
    assert_bun_status("invalid/16-rle-truncated.bun", BUN_MALFORMED);
